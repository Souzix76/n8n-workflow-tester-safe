{
  "name": "n8n-workflow-tester-safe",
  "version": "0.1.0",
  "description": "Safe MCP server + CLI for testing n8n workflows and scoring outputs without mutating workflows or credentials.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "n8n-test-safe": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "cli": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.2"
  }
}
